APP_NAME="Faraway Backend"
ENVIRONMENT="development"

# Auth
DEV_ALLOW_ANON_AUTH=false
DEV_TRUST_X_USER_HEADERS=false
SECRET_KEY="change-this-in-production-please-use-a-long-random-secret-key"
AUTH_TOKEN_TTL_HOURS=720
PASSWORD_HASH_ITERATIONS=120000
SMS_CODE_TTL_MINUTES=10

# Database
SQLITE_PATH="data/faraway_app.db"
SQLITE_JOURNAL_MODE="MEMORY"

# CORS
CORS_ORIGINS='["*"]'

# AI - Aliyun DashScope
DASHSCOPE_API_KEY="你的阿里云百炼API Key"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
DASHSCOPE_MODEL="qwen-plus"

# WeChat Open Platform
WECHAT_APP_ID="你的微信开放平台AppID"
WECHAT_APP_SECRET="你的微信开放平台AppSecret"

# Aliyun OSS
OSS_ACCESS_KEY_ID="你的AccessKey ID"
OSS_ACCESS_KEY_SECRET="你的AccessKey Secret"
OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"
OSS_BUCKET_NAME="你的Bucket名称"
OSS_PUBLIC_BASE_URL=""
OSS_UPLOAD_PREFIX="faraway"

# Upload limits
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=300
